# HaloPSA REST API base URL — your instance URL + /api
# e.g. https://yourcompany.halopsa.com/api
HALOPSA_BASE_URL=https://your-instance.halopsa.com/api

# OAuth2 credentials — create at HaloPSA > Configuration > Integrations > API
HALOPSA_CLIENT_ID=your_client_id_here
HALOPSA_CLIENT_SECRET=your_client_secret_here

# Tenant name — required for some HaloPSA instances. Leave blank if not used.
HALOPSA_TENANT=

# Override the auth token URL if your instance uses a non-standard path.
# Defaults to: HALOPSA_BASE_URL with /api replaced by /auth/token
# e.g. https://your-instance.halopsa.com/auth/token
# HALOPSA_AUTH_URL=

# Shared key that team members must provide to connect to this MCP server
# Generate a strong random string: openssl rand -hex 32
MCP_AUTH_KEY=change_me_to_a_strong_random_string

PORT=3003
NODE_ENV=production
